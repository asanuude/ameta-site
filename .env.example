# Скопируйте в .env.local для разработки. На Vercel — те же имена в Environment Variables.

# Обязательно для ответов нейросети (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Опционально: приватный raw GitHub — только если репозиторий с catalog.json закрытый
GITHUB_TOKEN=

# Источник каталога (массив товаров или { "products": [...] , опционально "groups" })
CATALOG_URL=https://raw.githubusercontent.com/asanuude/1c-data/main/catalog.json
#
# Регулярное обновление 1c-data: npm run catalog:build (нужны data/import*.xml + data/offers*.xml)
# либо GitHub Actions → workflow "Publish catalog to 1c-data" (см. секрет UPDATE_1C_DATA_PAT).

# Для OpenRouter (Referer)
SITE_URL=https://ameta.online

# Опционально: сколько строк каталога отдавать в ИИ (200–500), см. api/ask.js
# ASK_CATALOG_MAX_ITEMS=400
