# Скопируйте в .env.local для разработки. На Vercel — те же имена в Environment Variables.

# Обязательно для ответов нейросети (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Модель OpenRouter (см. /models). По умолчанию в коде: openai/gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_MAX_TOKENS=2048

# Опционально: приватный raw GitHub — только если репозиторий с catalog.json закрытый
GITHUB_TOKEN=

# Источник каталога (массив товаров или { "products": [...] , опционально "groups" })
CATALOG_URL=https://raw.githubusercontent.com/asanuude/1c-data/main/catalog.json
#
# Регулярное обновление 1c-data: npm run catalog:build (нужны data/import*.xml + data/offers*.xml)
# либо GitHub Actions → workflow "Publish catalog to 1c-data" (см. секрет UPDATE_1C_DATA_PAT).

# Для OpenRouter (Referer)
SITE_URL=https://ameta.online

# Опционально: сколько строк каталога отдавать в ИИ (200–500), см. api/ask.js
# ASK_CATALOG_MAX_ITEMS=400

# Автовыставление счёта: POST на опубликованный HTTP-сервис 1С (см. api/lib/invoice-1c.js)
# Расширение Agent: POST .../hs/agent/ameta/invoice (Bearer = ONEC_INVOICE_WEBHOOK_SECRET = константа API_AMetaInvoiceWebhookSecret в ИБ)
# Тело: organization (наименование нашей организации в КА), counterparty { organizationName, inn }, items
# Ответ: orderNumber, invoiceNumber, pdfUrl, viewUrl
# ONEC_INVOICE_WEBHOOK_URL=https://ваш-сервер/имяПубликации/hs/agent/ameta/invoice
# ONEC_INVOICE_WEBHOOK_SECRET=общий_секрет_как_в_1С
# Наименование организации-продавца в справочнике Организации (обязательно для вебхука Agent)
# AMETA_1C_ORGANIZATION_NAME=ООО Рога и копыта
# AMETA_1C_CONTRACT_NAME=
# AMETA_1C_POST_ORDER=false
# AMETA_1C_CREATE_COUNTERPARTY=true
#
# Проверка без секретов: GET /api/invoice-status (хост вебхука, флаг готовности к вызову)
