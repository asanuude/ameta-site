---
import CatalogSection from './CatalogSection.astro';
import { stockAvailabilityBand, stockAvailabilityLabel } from '../lib/stockAvailability';

interface Product {
	id?: string;
	name?: string;
	description?: string;
	sku?: string;
	price?: number | string;
	quantity?: number;
	groupId?: string | null;
	image?: string;
	enrichedDescription?: string;
	specs?: Array<{ name?: string; value?: string }>;
	enrichmentSourceUrl?: string;
	enrichmentSourceTitle?: string;
}

interface GroupNode {
	id: string;
	name: string;
	products: Product[];
	children: GroupNode[];
	branchProductCount: number;
}

const { node, level = 0, showHeader = true } = Astro.props as {
	node: GroupNode;
	level?: number;
	showHeader?: boolean;
};
const previewLimit = level <= 1 ? 4 : 3;

const posPlural = new Intl.PluralRules('ru');
function pluralPos(n: number): string {
	const r = posPlural.select(n);
	if (r === 'one') return 'позиция';
	if (r === 'few') return 'позиции';
	return 'позиций';
}

function pluralGoods(n: number): string {
	const r = posPlural.select(n);
	if (r === 'one') return 'товар';
	if (r === 'few') return 'товара';
	return 'товаров';
}

let folderMeta = '';
if (node.children.length > 0 && node.products.length > 0) {
	folderMeta = `В этой папке: ${node.products.length} ${pluralPos(node.products.length)} · всего с подразделами: ${node.branchProductCount} ${pluralPos(node.branchProductCount)}`;
} else if (node.children.length > 0) {
	folderMeta =
		node.branchProductCount > 0
			? `С подразделами: ${node.branchProductCount} ${pluralPos(node.branchProductCount)}`
			: 'Подразделы ниже';
} else if (node.products.length > 0) {
	folderMeta = `${node.products.length} ${pluralPos(node.products.length)}`;
}

function normalizeSearchText(value: unknown): string {
	return String(value || '')
		.toLowerCase()
		.replace(/ё/g, 'е')
		.replace(/[^a-zа-я0-9]+/gi, ' ')
		.replace(/\s+/g, ' ')
		.trim();
}

const folderSearch = normalizeSearchText(
	[
		node.name,
		folderMeta,
		...node.children.map((child) => child.name),
		...node.products.slice(0, 24).flatMap((product) => [product.name, product.sku, product.description]),
	].join(' ')
);

function getSectionPromo(id: string) {
	const promos = {
		'public-retail': {
			title: 'Для кассовых мест и торгового зала',
			text: 'Кассы, весы, сканеры, POS-оборудование и периферия для стабильной работы магазина и торговой точки.',
		},
		'public-food': {
			title: 'Для кухни, производства и торгового объекта',
			text: 'Холодильное, тепловое, нейтральное оборудование и инвентарь для кухни, цеха, склада и торгового зала.',
		},
		'public-video': {
			title: 'Для контроля и безопасности объекта',
			text: 'Камеры, регистраторы и сопутствующее оборудование для наблюдения, записи и контроля объекта.',
		},
		'public-software': {
			title: 'Для запуска и сопровождения программных решений',
			text: 'Программы, лицензии и цифровые сервисы для торговли, учета, кассовой работы и рабочих мест сотрудников.',
		},
	};
	return promos[id as keyof typeof promos] || null;
}

const sectionPromo = level === 0 ? getSectionPromo(node.id) : null;
---

<section
	class={`catalog-folder folder-block ${level === 0 ? 'catalog-folder--root' : ''}`}
	id={`cat-folder-${node.id}`}
	data-folder-id={node.id}
	data-folder-search={folderSearch}
>
	{
		showHeader && (
			<header class="catalog-folder-head">
				<span class="catalog-folder-icon" aria-hidden="true">{level === 0 ? '🏷️' : '📁'}</span>
				<div class="catalog-folder-titles">
					<p class="catalog-folder-kicker">{level === 0 ? 'Основной раздел' : 'Подраздел'}</p>
					<h2 class="folder-title">{node.name}</h2>
					{folderMeta && <p class="catalog-folder-meta">{folderMeta}</p>}
					{
						sectionPromo && (
							<div class="catalog-folder-promo">
								<strong>{sectionPromo.title}</strong>
								<span>{sectionPromo.text}</span>
							</div>
						)
					}
				</div>
			</header>
		)
	}

	{
		node.children.length > 0 && (
			<nav class="subfolder-nav" aria-label={`Подразделы: ${node.name}`}>
				<div class="subfolder-nav-title">Подразделы</div>
				<div class="subfolder-grid">
					{node.children.map((c) => (
						<a href={`#cat-folder-${c.id}`} class="subfolder-card">
							<span class="subfolder-card-icon" aria-hidden="true">
								📂
							</span>
							<span class="subfolder-card-name">{c.name}</span>
							{c.branchProductCount > 0 && (
								<span class="subfolder-card-count">
									{c.branchProductCount} {pluralPos(c.branchProductCount)}
								</span>
							)}
							<span class="subfolder-card-hint">Перейти ↓</span>
						</a>
					))}
				</div>
			</nav>
		)
	}

	{
		node.products.length > 0 && (
			<>
				<ul class="product-list product-grid" data-product-list data-expanded="false">
					{node.products.map((p, index) => (
						<li
							class={`product-card ${index >= previewLimit ? 'product-card--extra' : ''}`}
							data-product-search={normalizeSearchText(
								[p.name, p.sku, p.description, node.name].join(' ')
							)}
						>
							<div class="product-card-top">
								<div class="product-card-media">
									{
										p.image ? (
											<img src={p.image} alt={p.name || 'Товар'} loading="lazy" />
										) : (
											<span aria-hidden="true">📦</span>
										)
									}
								</div>
								<div class="product-card-main">
									<div class="product-name">{p.name}</div>
									{p.sku && <div class="product-sku">Артикул: {p.sku}</div>}
								</div>
							</div>
							{(p.enrichedDescription || p.description) && (
								<p class="product-desc">{p.enrichedDescription || p.description}</p>
							)}
							{
								Array.isArray(p.specs) &&
									p.specs.length > 0 && (
										<div class="product-specs">
											{p.specs.slice(0, 4).map((spec) => (
												<div class="product-spec">
													<strong>{spec.name}:</strong> <span>{spec.value}</span>
												</div>
											))}
										</div>
									)
							}
							<div class="product-meta">
								<span class="price">
									{typeof p.price === 'number'
										? `${p.price.toLocaleString('ru-RU')} ₽`
										: p.price}
								</span>
								<span
									class={`availability-badge availability-badge--${stockAvailabilityBand(p.quantity)}`}
								>
									{stockAvailabilityLabel(p.quantity)}
								</span>
							</div>
							<div class="product-card-footer">
								<span class="product-foot-note">{node.name}</span>
								<span class="product-link">
									{p.enrichmentSourceUrl ? 'Характеристики в карточке' : 'Уточнить у консультанта'}
								</span>
							</div>
						</li>
					))}
				</ul>
				{
					node.products.length > previewLimit && (
						<div class="product-list-actions">
							<button
								type="button"
								class="product-more-btn"
								data-products-toggle
								data-expand-label={`Показать еще ${node.products.length - previewLimit} ${pluralGoods(node.products.length - previewLimit)}`}
								data-collapse-label="Свернуть список"
							>
								Показать еще {node.products.length - previewLimit} {pluralGoods(node.products.length - previewLimit)}
							</button>
						</div>
					)
				}
			</>
		)
	}

	{
		node.children.map((child) => (
			<div class="folder-nested">
				<CatalogSection node={child} level={level + 1} />
			</div>
		))
	}
</section>

<style is:global>
	.folder-block {
		margin-bottom: 0;
	}

	.folder-nested {
		margin-top: 18px;
		padding-left: 18px;
		border-left: 2px solid #d8e2f0;
	}

	.catalog-folder {
		scroll-margin-top: 96px;
		margin-bottom: 24px;
	}

	.catalog-folder--root {
		margin-bottom: 34px;
		padding-bottom: 4px;
		border-bottom: 1px solid #edf2f8;
	}

	.catalog-folder-head {
		display: flex;
		align-items: flex-start;
		gap: 14px;
		padding: 20px;
		margin-bottom: 16px;
		border-radius: 22px;
		background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
		border: 1px solid #dae3ef;
	}

	.catalog-folder-icon {
		width: 50px;
		height: 50px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 18px;
		background: rgba(23, 78, 166, 0.08);
		font-size: 24px;
		line-height: 1;
		flex-shrink: 0;
	}

	.catalog-folder-titles {
		flex: 1;
		min-width: 0;
	}

	.catalog-folder-kicker {
		font-size: 12px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #174ea6;
		margin-bottom: 6px;
	}

	.folder-title {
		font-size: clamp(22px, 3vw, 30px);
		line-height: 1.15;
		letter-spacing: -0.03em;
		font-weight: 900;
		color: #10233f;
		margin-bottom: 8px;
	}

	.catalog-folder-meta {
		font-size: 14px;
		line-height: 1.55;
		color: #55657d;
	}

	.catalog-folder-promo {
		display: grid;
		gap: 6px;
		margin-top: 14px;
		padding: 14px 16px;
		border-radius: 18px;
		background: #eef4ff;
		border: 1px solid #d9e6ff;
	}

	.catalog-folder-promo strong {
		font-size: 14px;
		line-height: 1.35;
		color: #10233f;
	}

	.catalog-folder-promo span {
		font-size: 14px;
		line-height: 1.55;
		color: #4d6282;
	}

	.subfolder-nav {
		margin-bottom: 16px;
	}

	.subfolder-nav-title {
		font-size: 12px;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #5e6f8f;
		margin-bottom: 10px;
	}

	.subfolder-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
		gap: 12px;
	}

	.subfolder-card {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 6px;
		padding: 16px;
		background: #f8fbff;
		border: 1px solid #dae3ef;
		border-radius: 18px;
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.12s ease,
			box-shadow 0.12s ease,
			transform 0.12s ease;
	}

	.subfolder-card:hover {
		border-color: #8bb0f4;
		box-shadow: 0 10px 24px rgba(23, 78, 166, 0.1);
		transform: translateY(-1px);
	}

	.subfolder-card-icon {
		font-size: 18px;
	}

	.subfolder-card-name {
		font-size: 16px;
		font-weight: 800;
		line-height: 1.3;
		color: #10233f;
	}

	.subfolder-card-count {
		font-size: 13px;
		color: #55657d;
	}

	.subfolder-card-hint {
		font-size: 12px;
		font-weight: 800;
		color: #174ea6;
	}

	.product-list {
		list-style: none;
	}

	.product-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 14px;
	}

	.product-card {
		display: flex;
		flex-direction: column;
		gap: 14px;
		min-height: 220px;
		padding: 18px;
		border: 1px solid #dae3ef;
		border-radius: 22px;
		background: linear-gradient(180deg, #fff 0%, #f8fbff 100%);
		box-shadow: 0 10px 24px rgba(16, 35, 63, 0.06);
	}

	.product-list[data-expanded='false'] .product-card--extra {
		display: none;
	}

	.product-list-actions {
		margin-top: 12px;
		display: flex;
		justify-content: flex-start;
	}

	.product-more-btn {
		min-height: 42px;
		padding: 0 16px;
		border-radius: 999px;
		border: 1px solid #cddbf3;
		background: #fff;
		color: #174ea6;
		font-size: 13px;
		font-weight: 800;
		cursor: pointer;
	}

	.product-more-btn:hover {
		background: #f5f9ff;
		border-color: #a8c0ef;
	}

	.product-card-top {
		display: flex;
		align-items: flex-start;
		gap: 12px;
	}

	.product-card-media {
		width: 48px;
		height: 48px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 16px;
		background: rgba(23, 78, 166, 0.08);
		font-size: 22px;
		flex-shrink: 0;
		overflow: hidden;
	}

	.product-card-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.product-card-main {
		min-width: 0;
	}

	.product-name {
		font-size: 17px;
		line-height: 1.35;
		font-weight: 800;
		color: #10233f;
		margin-bottom: 6px;
	}

	.product-sku {
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #6f7f98;
	}

	.product-desc {
		font-size: 14px;
		line-height: 1.55;
		color: #55657d;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.product-specs {
		display: grid;
		gap: 8px;
		padding: 12px;
		border-radius: 16px;
		background: #f8fbff;
		border: 1px solid #e3ebf7;
	}

	.product-spec {
		font-size: 12px;
		line-height: 1.45;
		color: #55657d;
	}

	.product-spec strong {
		color: #10233f;
	}

	.product-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px 14px;
		margin-top: auto;
	}

	.price {
		font-size: 22px;
		line-height: 1;
		font-weight: 900;
		letter-spacing: -0.03em;
		color: #10233f;
	}

	.availability-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 32px;
		padding: 0 12px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 900;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.availability-badge--order {
		background: #fee2e2;
		color: #9d174d;
	}

	.availability-badge--low {
		background: #ffedd5;
		color: #9a3412;
	}

	.availability-badge--medium {
		background: #dbeafe;
		color: #1d4ed8;
	}

	.availability-badge--plenty {
		background: #d1fae5;
		color: #047857;
	}

	.product-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding-top: 12px;
		border-top: 1px solid #edf2f8;
	}

	.product-foot-note {
		font-size: 12px;
		line-height: 1.45;
		color: #55657d;
	}

	.product-link {
		display: inline-flex;
		align-items: center;
		font-size: 13px;
		font-weight: 800;
		color: #174ea6;
		white-space: nowrap;
	}

	.is-hidden {
		display: none !important;
	}

	@media (max-width: 720px) {
		.subfolder-grid,
		.product-grid {
			grid-template-columns: 1fr;
		}

		.product-card-footer {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
