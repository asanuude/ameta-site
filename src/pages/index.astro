<script>
  // Явно привязываем функции к глобальной области видимости
  window.isRecording = false;
  window.mediaRecorder = null;
  window.audioChunks = [];
  window.messagesDiv = document.getElementById('messages');
  window.userInput = document.getElementById('userInput');
  window.micButton = document.getElementById('micButton');

  window.addMessage = function(text, isUser = false) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${isUser ? 'user-message' : 'bot-message'}`;
    
    const formattedText = text.split('\n').map(line => {
      if (line.trim().startsWith('-')) {
        return `<li>${line.trim().substring(1)}</li>`;
      } else if (line.trim() !== '') {
        return `<p>${line}</p>`;
      }
      return '';
    }).join('');
    
    messageDiv.innerHTML = formattedText.includes('<li>') 
      ? `<ul>${formattedText}</ul>` 
      : formattedText;
    
    window.messagesDiv.appendChild(messageDiv);
    window.messagesDiv.scrollTop = window.messagesDiv.scrollHeight;
  };

  window.sendMessage = async function() {
    const text = window.userInput.value.trim();
    if (!text) return;

    window.addMessage(text, true);
    window.userInput.value = '';

    const typingIndicator = document.createElement('div');
    typingIndicator.className = 'typing-indicator';
    typingIndicator.innerHTML = '<span></span><span></span><span></span>';
    window.messagesDiv.appendChild(typingIndicator);
    window.messagesDiv.scrollTop = window.messagesDiv.scrollHeight;

    try {
      const response = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: text })
      });
      
      const data = await response.json();
      typingIndicator.remove();
      window.addMessage(data.answer);
    } catch (error) {
      typingIndicator.remove();
      window.addMessage('Произошла ошибка. Пожалуйста, попробуйте позже.');
    }
  };

  window.toggleRecording = async function() {
    if (!window.isRecording) {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        window.mediaRecorder = new MediaRecorder(stream);
        window.audioChunks = [];

        window.mediaRecorder.ondataavailable = event => {
          window.audioChunks.push(event.data);
        };

        window.mediaRecorder.onstop = async () => {
          window.addMessage('🎤 (Голосовое сообщение)', true);
          
          const typingIndicator = document.createElement('div');
          typingIndicator.className = 'typing-indicator';
          typingIndicator.innerHTML = '<span></span><span></span><span></span>';
          window.messagesDiv.appendChild(typingIndicator);
          
          setTimeout(() => {
            typingIndicator.remove();
            window.addMessage('Извините, распознавание голоса временно не работает. Пожалуйста, напишите ваш вопрос.');
          }, 2000);

          stream.getTracks().forEach(track => track.stop());
        };

        window.mediaRecorder.start();
        window.isRecording = true;
        window.micButton.classList.add('listening');
        window.micButton.style.background = '#e53e3e';
      } catch (error) {
        alert('Не удалось получить доступ к микрофону. Пожалуйста, разрешите доступ и попробуйте снова.');
      }
    } else {
      if (window.mediaRecorder && window.mediaRecorder.state !== 'inactive') {
        window.mediaRecorder.stop();
      }
      window.isRecording = false;
      window.micButton.classList.remove('listening');
      window.micButton.style.background = '#667eea';
    }
  };
</script>