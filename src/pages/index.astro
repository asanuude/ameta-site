---
// Файл: src/pages/index.astro
// Голосовой AI-консультант для ameta.online
import SpeedInsights from "@vercel/speed-insights/astro";
---

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
    <title>AMETA — AI-консультант</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .chat-container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 700px;
            overflow: hidden;
            animation: slideUp 0.5s ease;
            display: flex;
            flex-direction: column;
            height: 90vh;
            max-height: 800px;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 1.5rem;
            text-align: center;
            flex-shrink: 0;
        }

        .header h1 {
            font-size: 2rem;
            margin-bottom: 0.25rem;
            font-weight: 700;
        }

        .header p {
            font-size: 1rem;
            opacity: 0.95;
        }

        .header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            text-align: left;
            flex-wrap: wrap;
        }

        .catalog-link {
            color: #fff;
            font-weight: 600;
            text-decoration: none;
            padding: 0.4rem 0.9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.2);
            white-space: nowrap;
        }

        .catalog-link:hover {
            background: rgba(255, 255, 255, 0.35);
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
            background: #f8f9fa;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            min-height: 0;
        }

        .message {
            max-width: 85%;
            padding: 0.8rem 1.2rem;
            border-radius: 20px;
            animation: messageAppear 0.3s ease;
            line-height: 1.5;
            word-wrap: break-word;
        }

        @keyframes messageAppear {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .user-message {
            background: #007AFF;
            color: white;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .bot-message {
            background: white;
            color: #1a1a1a;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .bot-message p {
            margin: 0.5rem 0;
        }

        .bot-message ul {
            margin: 0.5rem 0 0.5rem 1.5rem;
        }

        .bot-message li {
            margin-left: 1rem;
        }

        .input-area {
            padding: 1rem;
            background: white;
            border-top: 1px solid #eee;
            display: flex;
            gap: 0.5rem;
            align-items: center;
            flex-shrink: 0;
        }

        .input-wrapper {
            flex: 1;
            display: flex;
            gap: 0.5rem;
            align-items: center;
            background: #f0f2f5;
            border-radius: 40px;
            padding: 0.25rem 0.5rem 0.25rem 1rem;
        }

        .input-wrapper input {
            flex: 1;
            border: none;
            background: transparent;
            padding: 0.75rem 0.5rem;
            font-size: 1rem;
            outline: none;
            min-width: 0;
        }

        .mic-button {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #667eea;
            border: none;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .mic-button:hover {
            background: #5a67d8;
            transform: scale(1.05);
        }

        .mic-button.listening {
            background: #e53e3e;
            animation: pulse 1.5s infinite;
        }

        .mic-button svg {
            width: 22px;
            height: 22px;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(229, 62, 62, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(229, 62, 62, 0); }
            100% { box-shadow: 0 0 0 0 rgba(229, 62, 62, 0); }
        }

        .send-button {
            background: #667eea;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 0.75rem 1.5rem;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .send-button:hover {
            background: #5a67d8;
        }

        .send-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .typing-indicator {
            display: flex;
            gap: 0.3rem;
            padding: 0.5rem 1rem;
            background: white;
            border-radius: 20px;
            width: fit-content;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .typing-indicator span {
            width: 8px;
            height: 8px;
            background: #667eea;
            border-radius: 50%;
            animation: typing 1s infinite ease-in-out;
        }

        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-10px); }
        }

        .error-message {
            color: #e53e3e;
            text-align: center;
            padding: 0.5rem;
            font-size: 0.9rem;
            background: #fff5f5;
            border-radius: 8px;
            margin: 0.5rem;
        }

        /* ===== МОБИЛЬНАЯ ВЕРСИЯ ===== */
        @media (max-width: 768px) {
            body {
                padding: 0;
            }

            .chat-container {
                border-radius: 0;
                height: 100vh;
                max-height: none;
            }

            .header {
                padding: 1rem;
            }

            .header h1 {
                font-size: 1.5rem;
            }

            .header p {
                font-size: 0.9rem;
            }

            .messages {
                padding: 1rem;
                gap: 0.75rem;
            }

            .message {
                max-width: 90%;
                font-size: 0.95rem;
                padding: 0.7rem 1rem;
            }

            .input-area {
                padding: 0.75rem;
                gap: 0.5rem;
                background: white;
                border-top: 1px solid #ddd;
            }

            .input-wrapper {
                background: #f0f2f5;
                border-radius: 30px;
                padding: 0.15rem 0.25rem 0.15rem 0.75rem;
            }

            .input-wrapper input {
                padding: 0.6rem 0.25rem;
                font-size: 16px;
            }

            .mic-button {
                width: 42px;
                height: 42px;
                flex-shrink: 0;
            }

            .mic-button svg {
                width: 20px;
                height: 20px;
            }

            .send-button {
                padding: 0.6rem 1rem;
                font-size: 0.9rem;
                min-width: 70px;
                text-align: center;
                margin-left: 15%;
                position: relative;
                left: -15%;
            }

            .send-button:active {
                transform: scale(0.95);
            }
        }

        /* Очень маленькие экраны (до 380px) */
        @media (max-width: 380px) {
            .input-area {
                padding: 0.5rem;
                gap: 0.35rem;
            }

            .input-wrapper {
                padding-left: 0.5rem;
            }

            .input-wrapper input {
                padding: 0.5rem 0.15rem;
                font-size: 15px;
            }

            .mic-button {
                width: 38px;
                height: 38px;
            }

            .send-button {
                padding: 0.5rem 0.75rem;
                font-size: 0.85rem;
                min-width: 60px;
                margin-left: 10%;
                left: -10%;
            }
        }
    </style>
</head>
<body>
    <div class="chat-container">
        <div class="header">
            <div class="header-row">
                <div>
                    <h1>AMETA</h1>
                    <p>AI-консультант для вашего бизнеса</p>
                </div>
                <a class="catalog-link" href="/catalog">Каталог</a>
            </div>
        </div>

        <div class="messages" id="messages">
            <div class="message bot-message">
                👋 Здравствуйте! Я AI-консультант AMETA. Могу помочь с подбором товаров, рассказать о характеристиках и наличии. Что вас интересует?
            </div>
        </div>

        <div class="input-area">
            <div class="input-wrapper">
                <input 
                    type="text" 
                    id="userInput" 
                    placeholder="Напишите ваш вопрос..."
                    autocomplete="off"
                >
                <button class="mic-button" id="micButton">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/>
                        <path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/>
                    </svg>
                </button>
            </div>
            <button class="send-button" id="sendButton">Отправить</button>
        </div>
    </div>

    <SpeedInsights />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Состояние
            let isRecording = false;
            let mediaRecorder = null;
            let audioChunks = [];
            let isSending = false;
            
            const messagesDiv = document.getElementById('messages');
            const userInput = document.getElementById('userInput');
            const micButton = document.getElementById('micButton');
            const sendButton = document.getElementById('sendButton');

            const SESSION_KEY = 'ameta_session_id';
            let sessionId = localStorage.getItem(SESSION_KEY);
            if (!sessionId) {
                sessionId = crypto.randomUUID();
                localStorage.setItem(SESSION_KEY, sessionId);
            }

            // Функция добавления сообщения
            function addMessage(text, isUser = false) {
                const messageDiv = document.createElement('div');
                messageDiv.className = `message ${isUser ? 'user-message' : 'bot-message'}`;
                
                if (text.includes('✅') || text.includes('**')) {
                    messageDiv.innerHTML = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                                               .replace(/\n/g, '<br>');
                } else {
                    messageDiv.textContent = text;
                }
                
                messagesDiv.appendChild(messageDiv);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            // Функция отправки сообщения
            async function sendMessage() {
                const text = userInput.value.trim();
                if (!text || isSending) return;

                isSending = true;
                sendButton.disabled = true;
                userInput.disabled = true;

                addMessage(text, true);
                userInput.value = '';

                const typingIndicator = document.createElement('div');
                typingIndicator.className = 'typing-indicator';
                typingIndicator.innerHTML = '<span></span><span></span><span></span>';
                messagesDiv.appendChild(typingIndicator);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;

                try {
                    const response = await fetch('/api/ask', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ question: text, sessionId })
                    });
                    
                    const data = await response.json();
                    typingIndicator.remove();
                    addMessage(data.answer || 'Пустой ответ от сервера');
                } catch (error) {
                    typingIndicator.remove();
                    addMessage('Произошла ошибка связи с сервером. Пожалуйста, попробуйте ещё раз.');
                    console.error('Send error:', error);
                } finally {
                    isSending = false;
                    sendButton.disabled = false;
                    userInput.disabled = false;
                    userInput.focus();
                }
            }

            // Функция записи голоса
            async function toggleRecording() {
                if (!isRecording) {
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                        mediaRecorder = new MediaRecorder(stream);
                        audioChunks = [];

                        mediaRecorder.ondataavailable = event => {
                            audioChunks.push(event.data);
                        };

                        mediaRecorder.onstop = async () => {
                            addMessage('🎤 (Голосовое сообщение)', true);
                            
                            const typingIndicator = document.createElement('div');
                            typingIndicator.className = 'typing-indicator';
                            typingIndicator.innerHTML = '<span></span><span></span><span></span>';
                            messagesDiv.appendChild(typingIndicator);
                            
                            setTimeout(() => {
                                typingIndicator.remove();
                                addMessage('Извините, распознавание голоса временно не работает. Пожалуйста, напишите ваш вопрос.');
                            }, 2000);

                            stream.getTracks().forEach(track => track.stop());
                        };

                        mediaRecorder.start();
                        isRecording = true;
                        micButton.classList.add('listening');
                    } catch (error) {
                        alert('Не удалось получить доступ к микрофону. Пожалуйста, разрешите доступ и попробуйте снова.');
                        console.error('Mic error:', error);
                    }
                } else {
                    if (mediaRecorder && mediaRecorder.state !== 'inactive') {
                        mediaRecorder.stop();
                    }
                    isRecording = false;
                    micButton.classList.remove('listening');
                }
            }

            // Привязываем события
            sendButton.addEventListener('click', sendMessage);
            micButton.addEventListener('click', toggleRecording);
            userInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter' && !isSending) {
                    sendMessage();
                }
            });

            // Фокус на поле ввода
            userInput.focus();
        });
    </script>
</body>
</html>