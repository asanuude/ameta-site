---
// Файл: src/pages/index.astro
// Главная страница AMETA: подбор оборудования и ПО
import SpeedInsights from "@vercel/speed-insights/astro";
---

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
    <title>AMETA — оборудование, ПО и сопровождение</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .chat-container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 700px;
            overflow: hidden;
            animation: slideUp 0.5s ease;
            display: flex;
            flex-direction: column;
            height: 90vh;
            max-height: 800px;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 1.5rem;
            text-align: center;
            flex-shrink: 0;
        }

        .header h1 {
            font-size: 2rem;
            margin-bottom: 0.25rem;
            font-weight: 700;
        }

        .header p {
            font-size: 1rem;
            opacity: 0.95;
        }

        .header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            text-align: left;
            flex-wrap: wrap;
        }

        .catalog-link {
            color: #fff;
            font-weight: 600;
            text-decoration: none;
            padding: 0.4rem 0.9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.2);
            white-space: nowrap;
        }

        .catalog-link:hover {
            background: rgba(255, 255, 255, 0.35);
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
            background: #f8f9fa;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            min-height: 0;
        }

        .message {
            max-width: 85%;
            padding: 0.8rem 1.2rem;
            border-radius: 20px;
            animation: messageAppear 0.3s ease;
            line-height: 1.5;
            word-wrap: break-word;
        }

        @keyframes messageAppear {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .user-message {
            background: #007AFF;
            color: white;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .bot-message {
            background: white;
            color: #1a1a1a;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .bot-message p {
            margin: 0.5rem 0;
        }

        .bot-message ul {
            margin: 0.5rem 0 0.5rem 1.5rem;
        }

        .bot-message li {
            margin-left: 1rem;
        }

        .catalog-paged-wrap {
            max-width: 100%;
        }

        .catalog-intro {
            margin-bottom: 0.75rem;
        }

        .catalog-item-list {
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            margin: 0.5rem 0 0.35rem;
        }

        .catalog-item-row {
            display: flex;
            gap: 0.5rem;
            align-items: flex-start;
            padding: 0.55rem 0.65rem;
            background: #f8f9fc;
            border-radius: 12px;
            border: 1px solid #e8eaf4;
        }

        .catalog-item-num {
            font-weight: 700;
            color: #667eea;
            flex-shrink: 0;
            min-width: 1.5rem;
        }

        .catalog-item-body {
            flex: 1;
            min-width: 0;
        }

        .catalog-item-name {
            font-weight: 500;
            margin-bottom: 0.25rem;
            word-wrap: break-word;
        }

        .catalog-item-meta {
            font-size: 0.88rem;
            color: #555;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 1rem;
            align-items: center;
        }

        .catalog-item-avail {
            display: inline-flex;
            align-items: center;
            padding: 0.15rem 0.55rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .catalog-item-avail--order {
            background: #fee2e2;
            color: #991b1b;
        }

        .catalog-item-avail--low {
            background: #ffedd5;
            color: #9a3412;
        }

        .catalog-item-avail--medium {
            background: #dbeafe;
            color: #1e40af;
        }

        .catalog-item-avail--plenty {
            background: #d1fae5;
            color: #065f46;
        }

        .catalog-item-footer {
            font-size: 0.82rem;
            color: #718096;
            margin-top: 0.25rem;
        }

        .catalog-btn-row {
            margin-top: 0.65rem;
        }

        .catalog-more-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border: none;
            border-radius: 999px;
            padding: 0.5rem 1.25rem;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
        }

        .catalog-more-btn:hover {
            filter: brightness(1.05);
        }

        .input-area {
            padding: 1rem;
            background: white;
            border-top: 1px solid #eee;
            display: flex;
            gap: 0.5rem;
            align-items: center;
            flex-shrink: 0;
        }

        .input-wrapper {
            flex: 1;
            display: flex;
            gap: 0.5rem;
            align-items: center;
            background: #f0f2f5;
            border-radius: 40px;
            padding: 0.25rem 0.5rem 0.25rem 1rem;
        }

        .input-wrapper input {
            flex: 1;
            border: none;
            background: transparent;
            padding: 0.75rem 0.5rem;
            font-size: 1rem;
            outline: none;
            min-width: 0;
        }

        .mic-button {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #667eea;
            border: none;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .mic-button:hover {
            background: #5a67d8;
            transform: scale(1.05);
        }

        .mic-button.listening {
            background: #e53e3e;
            animation: pulse 1.5s infinite;
        }

        .mic-button svg {
            width: 22px;
            height: 22px;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(229, 62, 62, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(229, 62, 62, 0); }
            100% { box-shadow: 0 0 0 0 rgba(229, 62, 62, 0); }
        }

        .send-button {
            background: #667eea;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 0.75rem 1.5rem;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .send-button:hover {
            background: #5a67d8;
        }

        .send-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .typing-status {
            align-self: flex-start;
            max-width: 92%;
            padding: 0.85rem 1.1rem;
            background: white;
            border-radius: 20px;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
            border: 1px solid rgba(102, 126, 234, 0.25);
            animation: statusPulse 2s ease-in-out infinite;
        }

        @keyframes statusPulse {
            0%, 100% { box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2); }
            50% { box-shadow: 0 4px 14px rgba(102, 126, 234, 0.35); }
        }

        .typing-status-line {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-bottom: 0.35rem;
        }

        .typing-status-title {
            font-weight: 600;
            color: #4c51bf;
            font-size: 0.95rem;
        }

        .typing-elapsed {
            font-variant-numeric: tabular-nums;
            font-size: 0.85rem;
            color: #718096;
            white-space: nowrap;
        }

        .typing-hint {
            margin: 0 0 0.5rem;
            font-size: 0.88rem;
            color: #4a5568;
            line-height: 1.45;
        }

        .typing-indicator {
            display: flex;
            gap: 0.3rem;
            padding: 0.15rem 0;
        }

        .typing-indicator span {
            width: 8px;
            height: 8px;
            background: #667eea;
            border-radius: 50%;
            animation: typing 1s infinite ease-in-out;
        }

        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-10px); }
        }

        .error-message {
            color: #e53e3e;
            text-align: center;
            padding: 0.5rem;
            font-size: 0.9rem;
            background: #fff5f5;
            border-radius: 8px;
            margin: 0.5rem;
        }

        /* ===== МОБИЛЬНАЯ ВЕРСИЯ ===== */
        @media (max-width: 768px) {
            body {
                padding: 0;
            }

            .chat-container {
                border-radius: 0;
                height: 100vh;
                max-height: none;
            }

            .header {
                padding: 1rem;
            }

            .header h1 {
                font-size: 1.5rem;
            }

            .header p {
                font-size: 0.9rem;
            }

            .messages {
                padding: 1rem;
                gap: 0.75rem;
            }

            .message {
                max-width: 90%;
                font-size: 0.95rem;
                padding: 0.7rem 1rem;
            }

            .input-area {
                padding: 0.75rem;
                gap: 0.5rem;
                background: white;
                border-top: 1px solid #ddd;
            }

            .input-wrapper {
                background: #f0f2f5;
                border-radius: 30px;
                padding: 0.15rem 0.25rem 0.15rem 0.75rem;
            }

            .input-wrapper input {
                padding: 0.6rem 0.25rem;
                font-size: 16px;
            }

            .mic-button {
                width: 42px;
                height: 42px;
                flex-shrink: 0;
            }

            .mic-button svg {
                width: 20px;
                height: 20px;
            }

            .send-button {
                padding: 0.6rem 1rem;
                font-size: 0.9rem;
                min-width: 70px;
                text-align: center;
                margin-left: 15%;
                position: relative;
                left: -15%;
            }

            .send-button:active {
                transform: scale(0.95);
            }
        }

        /* Очень маленькие экраны (до 380px) */
        @media (max-width: 380px) {
            .input-area {
                padding: 0.5rem;
                gap: 0.35rem;
            }

            .input-wrapper {
                padding-left: 0.5rem;
            }

            .input-wrapper input {
                padding: 0.5rem 0.15rem;
                font-size: 15px;
            }

            .mic-button {
                width: 38px;
                height: 38px;
            }

            .send-button {
                padding: 0.5rem 0.75rem;
                font-size: 0.85rem;
                min-width: 60px;
                margin-left: 10%;
                left: -10%;
            }
        }
    </style>
</head>
<body>
    <div class="chat-container">
        <div class="header">
            <div class="header-row">
                <div>
                    <h1>AMETA</h1>
                    <p>Подбор оборудования, ПО, внедрение и обслуживание</p>
                </div>
                <a class="catalog-link" href="/catalog">Каталог</a>
            </div>
        </div>

        <div class="messages" id="messages">
            <div class="message bot-message">
                Здравствуйте. Помогу подобрать оборудование и программное обеспечение для магазина, кафе, ресторана или производства, а также сориентирую по установке, подключению и обслуживанию. Что вы планируете модернизировать?
            </div>
        </div>

        <div class="input-area">
            <div class="input-wrapper">
                <input 
                    type="text" 
                    id="userInput" 
                    placeholder="Напишите ваш вопрос..."
                    autocomplete="off"
                >
                <button class="mic-button" id="micButton">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/>
                        <path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/>
                    </svg>
                </button>
            </div>
            <button class="send-button" id="sendButton">Отправить</button>
        </div>
    </div>

    <SpeedInsights />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Состояние
            let isRecording = false;
            let mediaRecorder = null;
            let audioChunks = [];
            let isSending = false;
            
            const messagesDiv = document.getElementById('messages');
            const userInput = document.getElementById('userInput');
            const micButton = document.getElementById('micButton');
            const sendButton = document.getElementById('sendButton');

            const SESSION_KEY = 'ameta_session_id';
            const LAST_USER_Q_KEY = 'ameta_last_user_query_for_invoice';
            let sessionId = localStorage.getItem(SESSION_KEY);
            if (!sessionId) {
                sessionId = crypto.randomUUID();
                localStorage.setItem(SESSION_KEY, sessionId);
            }

            const WAIT_HINTS = [
                'Подождите — запрос обрабатывается.',
                'Система не зависла: идёт подбор ответа.',
                'Иногда ответ занимает до 1–2 минут — это нормально.',
                'При оформлении счёта связь с учётной системой может занять чуть больше времени.',
            ];

            function escapeHtmlClient(s) {
                const d = document.createElement('div');
                d.textContent = s == null ? '' : String(s);
                return d.innerHTML;
            }

            function formatPriceRu(p) {
                if (typeof p === 'number' && Number.isFinite(p)) {
                    return p.toLocaleString('ru-RU');
                }
                const n = parseFloat(String(p).replace(/\s/g, '').replace(',', '.'));
                if (Number.isFinite(n)) return n.toLocaleString('ru-RU');
                return String(p);
            }

            /** Дублирует src/lib/stockAvailability.ts — шкала без точного остатка. */
            function parseQtyForAvail(raw) {
                if (raw === null || raw === undefined || raw === '') return NaN;
                const n =
                    typeof raw === 'number'
                        ? raw
                        : parseFloat(String(raw).replace(/\s/g, '').replace(',', '.'));
                return Number.isFinite(n) ? n : NaN;
            }

            function stockAvailabilityBandClient(raw) {
                const n = parseQtyForAvail(raw);
                if (!Number.isFinite(n) || n <= 0) return 'order';
                if (n <= 2) return 'low';
                if (n <= 10) return 'medium';
                return 'plenty';
            }

            function stockAvailabilityLabelClient(raw) {
                switch (stockAvailabilityBandClient(raw)) {
                    case 'order':
                        return 'Под заказ';
                    case 'low':
                        return 'Мало';
                    case 'medium':
                        return 'Много';
                    case 'plenty':
                        return 'Не иссякаемо';
                    default:
                        return 'Под заказ';
                }
            }

            /** Длинный список каталога: по pageSize позиций и кнопка «Дальше». */
            function addCatalogPagedMessage(introText, items, pageSize) {
                const ps = Math.max(1, parseInt(pageSize, 10) || 5);
                const wrap = document.createElement('div');
                wrap.className = 'message bot-message catalog-paged-wrap';

                const introDiv = document.createElement('div');
                introDiv.className = 'catalog-intro';
                const intro = String(introText || '');
                const useRich =
                    intro.includes('✅') ||
                    intro.includes('**') ||
                    intro.includes('](') ||
                    /https?:\/\//i.test(intro);
                if (useRich) {
                    let h = intro.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
                    h = h.replace(
                        /\[([^\]]+)]\((https?:[^)\s]+)\)/g,
                        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>'
                    );
                    h = h.replace(/\n/g, '<br>');
                    introDiv.innerHTML = h;
                } else {
                    introDiv.textContent = intro;
                }
                wrap.appendChild(introDiv);

                const listEl = document.createElement('div');
                listEl.className = 'catalog-item-list';
                wrap.appendChild(listEl);

                const footerEl = document.createElement('div');
                footerEl.className = 'catalog-item-footer';
                wrap.appendChild(footerEl);

                const btnRow = document.createElement('div');
                btnRow.className = 'catalog-btn-row';
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'catalog-more-btn';
                btn.textContent = 'Дальше';
                btnRow.appendChild(btn);
                wrap.appendChild(btnRow);

                let page = 0;

                function renderPage() {
                    const start = page * ps;
                    const slice = items.slice(start, start + ps);
                    listEl.innerHTML = '';
                    slice.forEach(function (item, idx) {
                        const globalIdx = start + idx + 1;
                        const row = document.createElement('div');
                        row.className = 'catalog-item-row';
                        const name = escapeHtmlClient(item.name || '');
                        const price = formatPriceRu(item.price);
                        const band = stockAvailabilityBandClient(item.quantity);
                        const availLabel = escapeHtmlClient(
                            stockAvailabilityLabelClient(item.quantity)
                        );
                        row.innerHTML =
                            '<span class="catalog-item-num">' +
                            globalIdx +
                            '.</span>' +
                            '<div class="catalog-item-body">' +
                            '<div class="catalog-item-name">' +
                            name +
                            '</div>' +
                            '<div class="catalog-item-meta">' +
                            '<span>Цена: ' +
                            escapeHtmlClient(price) +
                            ' руб.</span>' +
                            '<span class="catalog-item-avail catalog-item-avail--' +
                            band +
                            '">' +
                            availLabel +
                            '</span>' +
                            '</div></div>';
                        listEl.appendChild(row);
                    });
                    const shownEnd = Math.min(start + slice.length, items.length);
                    const shownStart = items.length ? start + 1 : 0;
                    footerEl.textContent =
                        items.length > 0
                            ? 'Показано ' + shownStart + '–' + shownEnd + ' из ' + items.length
                            : '';
                    btn.style.display = shownEnd < items.length ? 'inline-block' : 'none';
                }

                btn.addEventListener('click', function () {
                    page += 1;
                    renderPage();
                    messagesDiv.scrollTop = messagesDiv.scrollHeight;
                });

                renderPage();
                messagesDiv.appendChild(wrap);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            /** Блок «думаю» с таймером и сменой подсказок — снимает ощущение «зависания». */
            function appendTypingStatus() {
                const wrap = document.createElement('div');
                wrap.className = 'typing-status';
                wrap.innerHTML =
                    '<div class="typing-status-line">' +
                    '<span class="typing-status-title">Думаю над ответом…</span>' +
                    '<span class="typing-elapsed">0:00</span></div>' +
                    '<p class="typing-hint"></p>' +
                    '<div class="typing-indicator"><span></span><span></span><span></span></div>';

                const elapsedEl = wrap.querySelector('.typing-elapsed');
                const hintEl = wrap.querySelector('.typing-hint');
                hintEl.textContent = WAIT_HINTS[0];

                messagesDiv.appendChild(wrap);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;

                let sec = 0;
                let hintIndex = 0;
                const timerIv = setInterval(function () {
                    sec += 1;
                    const m = Math.floor(sec / 60);
                    const s = sec % 60;
                    elapsedEl.textContent = m + ':' + (s < 10 ? '0' : '') + s;
                }, 1000);

                const hintIv = setInterval(function () {
                    hintIndex = (hintIndex + 1) % WAIT_HINTS.length;
                    hintEl.textContent = WAIT_HINTS[hintIndex];
                }, 4500);

                return {
                    remove: function () {
                        clearInterval(timerIv);
                        clearInterval(hintIv);
                        wrap.remove();
                    },
                };
            }

            // Функция добавления сообщения
            function addMessage(text, isUser = false) {
                const messageDiv = document.createElement('div');
                messageDiv.className = `message ${isUser ? 'user-message' : 'bot-message'}`;

                const useRichBot =
                    !isUser &&
                    (text.includes('✅') ||
                        text.includes('**') ||
                        text.includes('](') ||
                        /https?:\/\//i.test(text));

                if (useRichBot) {
                    let h = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
                    h = h.replace(
                        /\[([^\]]+)]\((https?:[^)\s]+)\)/g,
                        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>'
                    );
                    h = h.replace(/\n/g, '<br>');
                    messageDiv.innerHTML = h;
                } else {
                    messageDiv.textContent = text;
                }

                messagesDiv.appendChild(messageDiv);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            // Функция отправки сообщения
            async function sendMessage() {
                const text = userInput.value.trim();
                if (!text || isSending) return;

                isSending = true;
                sendButton.disabled = true;
                userInput.disabled = true;

                addMessage(text, true);
                userInput.value = '';

                const typing = appendTypingStatus();

                try {
                    const lastUserProductQuery =
                        localStorage.getItem(LAST_USER_Q_KEY) || '';
                    const response = await fetch('/api/ask', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            question: text,
                            sessionId,
                            lastUserProductQuery,
                        }),
                    });

                    const data = await response.json();
                    typing.remove();
                    if (
                        data.catalogItems &&
                        Array.isArray(data.catalogItems) &&
                        data.catalogItems.length > 0
                    ) {
                        addCatalogPagedMessage(
                            data.answer || '',
                            data.catalogItems,
                            data.catalogPageSize
                        );
                    } else {
                        addMessage(data.answer || 'Пустой ответ от сервера');
                    }

                    const t = text;
                    const short = t.length <= 52;
                    const looksLikeBareInvoice =
                        short &&
                        /(?:сч[её]т|счет)/iu.test(t) &&
                        !t.includes('|') &&
                        !/\sна\s+\S{4,}/iu.test(t);
                    if (!looksLikeBareInvoice && t.length >= 8 && t.length <= 900) {
                        localStorage.setItem(LAST_USER_Q_KEY, t);
                    }
                } catch (error) {
                    typing.remove();
                    addMessage('Произошла ошибка связи с сервером. Пожалуйста, попробуйте ещё раз.');
                    console.error('Send error:', error);
                } finally {
                    isSending = false;
                    sendButton.disabled = false;
                    userInput.disabled = false;
                    userInput.focus();
                }
            }

            // Функция записи голоса
            async function toggleRecording() {
                if (!isRecording) {
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                        mediaRecorder = new MediaRecorder(stream);
                        audioChunks = [];

                        mediaRecorder.ondataavailable = event => {
                            audioChunks.push(event.data);
                        };

                        mediaRecorder.onstop = async () => {
                            addMessage('🎤 (Голосовое сообщение)', true);
                            
                            const typing = appendTypingStatus();
                            
                            setTimeout(() => {
                                typing.remove();
                                addMessage('Извините, распознавание голоса временно не работает. Пожалуйста, напишите ваш вопрос.');
                            }, 2000);

                            stream.getTracks().forEach(track => track.stop());
                        };

                        mediaRecorder.start();
                        isRecording = true;
                        micButton.classList.add('listening');
                    } catch (error) {
                        alert('Не удалось получить доступ к микрофону. Пожалуйста, разрешите доступ и попробуйте снова.');
                        console.error('Mic error:', error);
                    }
                } else {
                    if (mediaRecorder && mediaRecorder.state !== 'inactive') {
                        mediaRecorder.stop();
                    }
                    isRecording = false;
                    micButton.classList.remove('listening');
                }
            }

            // Привязываем события
            sendButton.addEventListener('click', sendMessage);
            micButton.addEventListener('click', toggleRecording);
            userInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter' && !isSending) {
                    sendMessage();
                }
            });

            // Фокус на поле ввода
            userInput.focus();
        });
    </script>
</body>
</html>