---
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCatalogStorefront } from '../lib/catalogStorefront';

const { products, sections, stats } = getCatalogStorefront();
const hasSections = sections.length > 0;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Каталог — AMETA</title>
		<style>
			:root {
				color-scheme: light;
				--bg: #eff4fb;
				--panel: #ffffff;
				--panel-soft: #f8fbff;
				--text: #10233f;
				--muted: #55657d;
				--brand: #174ea6;
				--brand-soft: #eef4ff;
				--line: #dae3ef;
				--line-strong: #c1d1e6;
				--shadow: 0 18px 44px rgba(16, 35, 63, 0.12);
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			body {
				font-family:
					Inter,
					system-ui,
					-apple-system,
					sans-serif;
				background:
					radial-gradient(circle at top, rgba(23, 78, 166, 0.08), transparent 30%),
					linear-gradient(180deg, #f3f7fc 0%, var(--bg) 100%);
				color: var(--text);
				padding: 20px 16px 48px;
			}

			.wrap {
				max-width: 1260px;
				margin: 0 auto;
			}

			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.9fr);
				gap: 18px;
				margin-bottom: 20px;
			}

			.hero-card,
			.hero-side,
			.toolbar,
			.quick-nav,
			.image-policy {
				background: rgba(255, 255, 255, 0.94);
				border: 1px solid rgba(218, 227, 239, 0.9);
				border-radius: 28px;
				box-shadow: var(--shadow);
				backdrop-filter: blur(10px);
			}

			.hero-card {
				padding: 28px;
				background:
					linear-gradient(135deg, rgba(23, 78, 166, 0.1), rgba(23, 78, 166, 0) 55%),
					linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
			}

			.breadcrumbs {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 8px 12px;
				margin-bottom: 18px;
				border-radius: 999px;
				background: var(--brand-soft);
				color: var(--brand);
				font-size: 13px;
				font-weight: 700;
			}

			.hero-title {
				font-size: clamp(34px, 5vw, 54px);
				line-height: 0.98;
				letter-spacing: -0.04em;
				font-weight: 900;
				max-width: 14ch;
				margin-bottom: 16px;
			}

			.hero-text {
				max-width: 68ch;
				font-size: 17px;
				line-height: 1.7;
				color: var(--muted);
				margin-bottom: 22px;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
			}

			.hero-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 46px;
				padding: 0 18px;
				border-radius: 999px;
				font-size: 14px;
				font-weight: 800;
				text-decoration: none;
				transition:
					transform 0.12s ease,
					box-shadow 0.12s ease,
					background 0.12s ease;
			}

			.hero-btn:hover {
				transform: translateY(-1px);
			}

			.hero-btn--light {
				background: var(--brand);
				color: #fff;
				box-shadow: 0 14px 28px rgba(23, 78, 166, 0.22);
			}

			.hero-btn--ghost {
				background: #fff;
				color: var(--brand);
				border: 1px solid var(--line-strong);
			}

			.hero-side {
				padding: 24px;
				display: grid;
				gap: 20px;
				align-content: start;
			}

			.hero-side-title,
			.section-kicker {
				font-size: 12px;
				font-weight: 900;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--brand);
			}

			.hero-side-title {
				margin-bottom: 12px;
			}

			.hero-side-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 12px;
			}

			.stat-card {
				padding: 18px 16px;
				border-radius: 20px;
				background: linear-gradient(180deg, #fff 0%, #f5f9ff 100%);
				border: 1px solid var(--line);
			}

			.stat-value {
				font-size: clamp(24px, 3vw, 32px);
				line-height: 1;
				font-weight: 900;
				letter-spacing: -0.04em;
				color: var(--text);
				margin-bottom: 6px;
			}

			.stat-label {
				font-size: 12px;
				line-height: 1.45;
				color: var(--muted);
			}

			.hero-notes {
				display: grid;
				gap: 12px;
			}

			.hero-note {
				padding: 16px 18px;
				border-radius: 18px;
				background: var(--panel-soft);
				border: 1px solid var(--line);
				color: var(--muted);
				font-size: 14px;
				line-height: 1.6;
			}

			.hero-note strong {
				display: block;
				color: var(--text);
				font-size: 15px;
				margin-bottom: 6px;
			}

			.toolbar {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 14px;
				align-items: center;
				padding: 16px 18px;
				margin-bottom: 18px;
			}

			.search-wrap {
				position: relative;
			}

			.search-input {
				width: 100%;
				min-height: 52px;
				padding: 0 18px 0 48px;
				border-radius: 18px;
				border: 1px solid var(--line);
				background: #f8fbff;
				font-size: 15px;
				color: var(--text);
				outline: none;
			}

			.search-input:focus {
				border-color: #8bb0f4;
				box-shadow: 0 0 0 4px rgba(23, 78, 166, 0.12);
			}

			.search-icon {
				position: absolute;
				left: 16px;
				top: 50%;
				transform: translateY(-50%);
				font-size: 18px;
				color: #6b7c95;
				pointer-events: none;
			}

			.toolbar-text {
				display: flex;
				align-items: center;
				gap: 6px;
				font-size: 14px;
				color: var(--muted);
			}

			.quick-nav,
			.image-policy {
				padding: 22px;
				margin-bottom: 18px;
			}

			.quick-nav-head {
				display: flex;
				flex-wrap: wrap;
				align-items: end;
				justify-content: space-between;
				gap: 12px;
				margin-bottom: 16px;
			}

			.section-title {
				font-size: clamp(24px, 3vw, 32px);
				line-height: 1.1;
				letter-spacing: -0.03em;
				font-weight: 900;
				color: var(--text);
			}

			.section-text {
				font-size: 15px;
				line-height: 1.6;
				color: var(--muted);
				max-width: 74ch;
			}

			.root-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 16px;
			}

			.root-card {
				display: flex;
				flex-direction: column;
				gap: 14px;
				min-height: 100%;
				padding: 18px;
				border-radius: 24px;
				border: 1px solid var(--line);
				background: linear-gradient(180deg, #fff 0%, #f8fbff 100%);
				text-decoration: none;
				transition:
					transform 0.12s ease,
					box-shadow 0.12s ease,
					border-color 0.12s ease;
			}

			.root-card:hover {
				transform: translateY(-2px);
				border-color: #8bb0f4;
				box-shadow: 0 12px 28px rgba(23, 78, 166, 0.12);
			}

			.root-card-media {
				overflow: hidden;
				border-radius: 18px;
				border: 1px solid #d9e6ff;
				background: #eef4ff;
				aspect-ratio: 16 / 10;
			}

			.root-card-media img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.root-card-title {
				font-size: 20px;
				font-weight: 900;
				line-height: 1.2;
				color: var(--text);
			}

			.root-card-copy {
				font-size: 14px;
				line-height: 1.6;
				color: var(--muted);
			}

			.root-card-meta {
				font-size: 13px;
				line-height: 1.5;
				color: var(--muted);
			}

			.root-card-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-top: auto;
			}

			.root-card-tags span {
				display: inline-flex;
				align-items: center;
				padding: 6px 10px;
				border-radius: 999px;
				background: #eef4ff;
				color: var(--brand);
				font-size: 12px;
				font-weight: 700;
			}

			.root-card-link {
				font-size: 13px;
				font-weight: 800;
				color: var(--brand);
			}

			.image-policy-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 14px;
				margin-top: 16px;
			}

			.image-card {
				padding: 18px;
				border-radius: 20px;
				background: linear-gradient(180deg, #fff 0%, #f8fbff 100%);
				border: 1px solid var(--line);
			}

			.image-card strong {
				display: block;
				margin-bottom: 8px;
				font-size: 15px;
				color: var(--text);
			}

			.image-card span {
				display: block;
				font-size: 14px;
				line-height: 1.6;
				color: var(--muted);
			}

			.catalog-empty,
			.catalog-results-empty {
				padding: 36px;
				border-radius: 20px;
				background: #f8fbff;
				border: 1px dashed var(--line-strong);
				color: var(--muted);
				text-align: center;
				font-size: 16px;
				line-height: 1.6;
			}

			.catalog-results-empty {
				display: none;
				margin-top: 16px;
			}

			.catalog-results-empty.is-visible {
				display: block;
			}

			.is-hidden {
				display: none !important;
			}

			@media (max-width: 1024px) {
				.hero {
					grid-template-columns: 1fr;
				}

				.toolbar,
				.image-policy-grid,
				.hero-side-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				body {
					padding: 14px 12px 32px;
				}

				.hero-card,
				.hero-side,
				.toolbar,
				.quick-nav,
				.image-policy {
					border-radius: 20px;
					padding: 18px;
				}

				.root-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<div class="wrap">
			<section class="hero">
				<div class="hero-card">
					<div class="breadcrumbs">
						<span>AMETA</span>
						<span>/</span>
						<span>Каталог оборудования</span>
					</div>
					<h1 class="hero-title">Оборудование и ПО для модернизации бизнеса</h1>
					<p class="hero-text">
						Выберите направление, которое подходит под вашу задачу, и перейдите к оборудованию,
						программному обеспечению и сопутствующим позициям для торговли, кухни, безопасности или учета.
					</p>
					<div class="hero-actions">
						<a class="hero-btn hero-btn--light" href="#catalog-sections">Открыть разделы</a>
						<a class="hero-btn hero-btn--ghost" href="/">Обсудить проект</a>
					</div>
				</div>

				<aside class="hero-side">
					<div>
						<p class="hero-side-title">Каталог в цифрах</p>
						<div class="hero-side-grid">
							{
								stats.map((item) => (
									<div class="stat-card">
										<div class="stat-value">{item.value}</div>
										<div class="stat-label">{item.label}</div>
									</div>
								))
							}
						</div>
					</div>
					<div class="hero-notes">
						<div class="hero-note">
							<strong>Подбор по типу объекта</strong>
							Отдельные разделы помогают быстрее перейти к товарам для магазина, кухни, склада, офиса
							или производственной площадки.
						</div>
						<div class="hero-note">
							<strong>Понятная навигация по каталогу</strong>
							Внутри направлений товары собраны по типу оборудования, чтобы проще было быстро найти
							нужную категорию и перейти к подходящим позициям.
						</div>
					</div>
				</aside>
			</section>

			<div class="toolbar">
				<div class="search-wrap">
					<input
						class="search-input"
						type="search"
						placeholder="Поиск по направлению, задаче или типу оборудования"
						data-catalog-search
					/>
					<span class="search-icon" aria-hidden="true">⌕</span>
				</div>
				<div class="toolbar-text">
					<strong>Поиск:</strong>
					быстрый фильтр по разделам каталога.
				</div>
			</div>

			{
				products.length === 0 ? (
					<div class="catalog-empty">
						Каталог пуст. Загрузите выгрузку 1С или заполните <code>public/catalog.json</code>.
					</div>
				) : (
					<>
						{hasSections && (
							<section class="quick-nav" id="catalog-sections">
								<div class="quick-nav-head">
									<div>
										<p class="section-kicker">Основные направления</p>
										<h2 class="section-title">Подберите нужный блок оборудования или ПО</h2>
									</div>
									<p class="section-text">
										Откройте нужный раздел и переходите к товарам для торговли, кухни,
										видеонаблюдения или программного обеспечения в зависимости от задач вашего
										бизнеса.
									</p>
								</div>
								<div class="root-grid">
									{
										sections.map((section) => (
											<a
												class="root-card"
												href={`/catalog/${section.meta.slug}`}
												data-root-card-search={`${section.meta.name} ${section.meta.cardCopy} ${section.meta.tags.join(' ')} ${section.node.children.map((child) => child.name).join(' ')}`}
											>
												<div class="root-card-media">
													<img src={section.meta.image} alt={section.meta.name} loading="lazy" />
												</div>
												<div class="root-card-title">{section.meta.name}</div>
												<div class="root-card-copy">{section.meta.cardCopy}</div>
												<div class="root-card-meta">
													{section.node.branchProductCount.toLocaleString('ru-RU')} позиций в разделе
												</div>
												<div class="root-card-tags">
													{section.meta.tags.map((tag) => <span>{tag}</span>)}
												</div>
												<div class="root-card-link">Открыть раздел</div>
											</a>
										))
									}
								</div>
								<div class="catalog-results-empty" data-catalog-empty>
									По вашему запросу разделы не найдены. Попробуйте другое название направления.
								</div>
							</section>
						)}

						<section class="image-policy">
							<div class="quick-nav-head">
								<div>
									<p class="section-kicker">Помощь с выбором</p>
									<h2 class="section-title">Как быстрее подобрать подходящее решение</h2>
								</div>
								<p class="section-text">
									Если вы пока не уверены в точной модели, начните с нужного направления и типа
									оборудования. Так проще отобрать подходящие позиции по задаче и формату объекта.
								</p>
							</div>
							<div class="image-policy-grid">
								<div class="image-card">
									<strong>Для новой точки</strong>
									<span>
										Если вы открываете магазин, кафе, пекарню или склад, начните с раздела по профилю
										объекта и переходите к нужным категориям техники.
									</span>
								</div>
								<div class="image-card">
									<strong>Для замены оборудования</strong>
									<span>
										Если требуется заменить кассу, весы, холодильник, камеру или программу,
										используйте поиск по типу оборудования, артикулу или названию модели.
									</span>
								</div>
								<div class="image-card">
									<strong>Для комплексного подбора</strong>
									<span>
										Когда нужен комплект под объект целиком, можно последовательно пройти по разделам:
										оборудование, программы, безопасность и сопутствующие позиции.
									</span>
								</div>
							</div>
						</section>
					</>
				)
			}
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', function () {
				const input = document.querySelector('[data-catalog-search]');
				const cards = Array.from(document.querySelectorAll('[data-root-card-search]'));
				const empty = document.querySelector('[data-catalog-empty]');

				function normalize(text) {
					return String(text || '')
						.toLowerCase()
						.replace(/ё/g, 'е')
						.replace(/[^a-zа-я0-9]+/gi, ' ')
						.replace(/\s+/g, ' ')
						.trim();
				}

				function applySearch() {
					if (!input) return;
					const query = normalize(input.value);

					cards.forEach(function (card) {
						if (!query) {
							card.classList.remove('is-hidden');
							return;
						}
						const haystack = normalize(card.getAttribute('data-root-card-search'));
						card.classList.toggle('is-hidden', !haystack.includes(query));
					});

					if (empty) {
						const hasVisible = cards.some(function (card) {
							return !card.classList.contains('is-hidden');
						});
						empty.classList.toggle('is-visible', !hasVisible && query.length > 0);
					}
				}

				if (input) {
					input.addEventListener('input', applySearch);
				}
			});
		</script>

		<SpeedInsights />
	</body>
</html>
