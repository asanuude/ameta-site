---
import fs from 'node:fs';
import path from 'node:path';
import CatalogSection from '../components/CatalogSection.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { stockAvailabilityBand, stockAvailabilityLabel } from '../lib/stockAvailability';

interface Group {
	id: string;
	name: string;
	parentId?: string | null;
}

interface Product {
	id?: string;
	name?: string;
	description?: string;
	sku?: string;
	price?: number | string;
	quantity?: number;
	groupId?: string | null;
}

interface GroupNode {
	id: string;
	name: string;
	products: Product[];
	children: GroupNode[];
	/** Позиции в этом узле и во всех вложенных папках */
	branchProductCount: number;
}

const catalogPath = path.join(process.cwd(), 'public', 'catalog.json');
let groups: Group[] = [];
let products: Product[] = [];

try {
	const raw = JSON.parse(fs.readFileSync(catalogPath, 'utf-8')) as
		| { groups?: Group[]; products?: Product[] }
		| Product[];
	if (Array.isArray(raw)) {
		products = raw;
	} else {
		groups = raw.groups ?? [];
		products = raw.products ?? [];
	}
} catch {
	/* нет файла — пустой каталог */
}

function buildTree(parentId: string | null | undefined): GroupNode[] {
	return groups
		.filter((g) => (g.parentId ?? null) === (parentId ?? null))
		.map((g) => {
			const children = buildTree(g.id);
			const ownProducts = products.filter((p) => p.groupId === g.id);
			const inChildren = children.reduce((sum, ch) => sum + ch.branchProductCount, 0);
			return {
				id: g.id,
				name: g.name,
				products: ownProducts,
				children,
				branchProductCount: ownProducts.length + inChildren,
			};
		});
}

const groupIds = new Set(groups.map((g) => g.id));
const orphans = products.filter((p) => !p.groupId || !groupIds.has(p.groupId));

const tree = buildTree(null);
const showTree = groups.length > 0;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Каталог — AMETA</title>
		<style>
			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}
			body {
				font-family:
					-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
				background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
				min-height: 100vh;
				color: #1a1a1a;
				padding: 1rem;
			}
			.wrap {
				max-width: 960px;
				margin: 0 auto;
			}
			.top {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.5rem;
			}
			.top h1 {
				color: #fff;
				font-size: 1.75rem;
				font-weight: 800;
				letter-spacing: -0.02em;
			}
			.top .hint {
				color: rgba(255, 255, 255, 0.75);
				font-size: 0.9rem;
				max-width: 420px;
			}
			.nav {
				display: flex;
				gap: 0.75rem;
			}
			.nav a {
				color: #fff;
				text-decoration: none;
				padding: 0.5rem 1rem;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.12);
				font-weight: 600;
				font-size: 0.9rem;
			}
			.nav a:hover {
				background: rgba(255, 255, 255, 0.22);
			}
			.panel {
				background: #fff;
				border-radius: 20px;
				padding: 1.5rem;
				box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
			}
			.folder-block {
				margin-bottom: 0;
			}
			.folder-nested {
				margin-top: 1.25rem;
				margin-left: 0;
				padding-left: 1.15rem;
				border-left: 3px solid #c7d2fe;
			}
			.catalog-folder {
				scroll-margin-top: 1rem;
				margin-bottom: 2rem;
			}
			.catalog-folder-head {
				display: flex;
				align-items: flex-start;
				gap: 0.85rem;
				padding: 1rem 1.15rem;
				margin-bottom: 1rem;
				background: linear-gradient(120deg, #f8fafc 0%, #eef2ff 100%);
				border-radius: 16px;
				border: 1px solid #e2e8f0;
			}
			.catalog-folder-icon {
				font-size: 1.75rem;
				line-height: 1;
				filter: drop-shadow(0 2px 4px rgba(15, 52, 96, 0.12));
			}
			.catalog-folder-titles {
				flex: 1;
				min-width: 0;
			}
			.folder-title {
				font-size: 1.25rem;
				margin: 0 0 0.35rem;
				color: #0f3460;
				font-weight: 800;
				letter-spacing: -0.02em;
				line-height: 1.25;
			}
			.catalog-folder-meta {
				margin: 0;
				font-size: 0.88rem;
				color: #64748b;
				font-weight: 500;
			}
			.subfolder-nav {
				margin-bottom: 1.25rem;
			}
			.subfolder-nav-title {
				font-size: 0.72rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				color: #64748b;
				margin-bottom: 0.65rem;
			}
			.subfolder-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 0.75rem;
			}
			.subfolder-card {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 0.25rem;
				padding: 0.85rem 1rem;
				background: #fff;
				border: 1px solid #e2e8f0;
				border-radius: 14px;
				text-decoration: none;
				color: inherit;
				transition:
					border-color 0.15s ease,
					box-shadow 0.15s ease,
					transform 0.12s ease;
				box-shadow: 0 2px 8px rgba(15, 52, 96, 0.06);
			}
			.subfolder-card:hover {
				border-color: #818cf8;
				box-shadow: 0 6px 20px rgba(67, 56, 202, 0.12);
				transform: translateY(-1px);
			}
			.subfolder-card-icon {
				font-size: 1.35rem;
				line-height: 1;
			}
			.subfolder-card-name {
				font-weight: 700;
				font-size: 0.95rem;
				color: #0f3460;
				line-height: 1.3;
			}
			.subfolder-card-hint {
				font-size: 0.75rem;
				font-weight: 600;
				color: #6366f1;
			}
			.subfolder-card-count {
				font-size: 0.78rem;
				color: #94a3b8;
				font-weight: 500;
			}
			.product-list {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.product-card {
				background: #f4f6fb;
				border-radius: 12px;
				padding: 1rem 1.1rem;
				border: 1px solid #e2e8f0;
			}
			.product-name {
				font-weight: 700;
				font-size: 1.05rem;
				margin-bottom: 0.25rem;
			}
			.product-sku {
				font-size: 0.8rem;
				color: #64748b;
				margin-bottom: 0.35rem;
			}
			.product-desc {
				font-size: 0.9rem;
				color: #475569;
				line-height: 1.45;
				margin-bottom: 0.5rem;
			}
			.product-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				font-size: 0.9rem;
			}
			.price {
				font-weight: 800;
				color: #0f3460;
			}
			.availability-badge {
				display: inline-flex;
				align-items: center;
				padding: 0.2rem 0.65rem;
				border-radius: 999px;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.02em;
			}
			.availability-badge--order {
				background: #fee2e2;
				color: #991b1b;
			}
			.availability-badge--low {
				background: #ffedd5;
				color: #9a3412;
			}
			.availability-badge--medium {
				background: #dbeafe;
				color: #1e40af;
			}
			.availability-badge--plenty {
				background: #d1fae5;
				color: #065f46;
			}
			.catalog-tree-intro {
				margin-bottom: 1.75rem;
				padding: 1.1rem 1.25rem;
				background: linear-gradient(135deg, #f0f4ff 0%, #e8f4fc 100%);
				border-radius: 16px;
				border: 1px solid #c7d2fe;
			}
			.catalog-tree-intro-lead {
				font-size: 0.72rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #4338ca;
				margin-bottom: 0.35rem;
			}
			.catalog-tree-intro-text {
				font-size: 0.95rem;
				color: #334155;
				line-height: 1.5;
				margin: 0;
			}
			.empty {
				text-align: center;
				padding: 2rem;
				color: #64748b;
			}
		</style>
	</head>
	<body>
		<div class="wrap">
			<div class="top">
				<div>
					<h1>Каталог</h1>
					<p class="hint">
						Справочник групп как в 1С: удобный просмотр по папкам. Наличие показано шкалой (без точного
						остатка). Обновление каталога — POST <code>/api/update-catalog</code> (import*.xml).
					</p>
				</div>
				<nav class="nav">
					<a href="/">Консультант</a>
				</nav>
			</div>
			<div class="panel">
				{
					products.length === 0 ? (
						<p class="empty">Каталог пуст. Загрузите выгрузку 1С или заполните public/catalog.json.</p>
					) : showTree ? (
						<>
							<div class="catalog-tree-intro">
								<p class="catalog-tree-intro-lead">Навигация по разделам</p>
								<p class="catalog-tree-intro-text">
									Выберите подраздел ниже — страница прокрутится к нужной папке. В каждой карточке
									товара указана доступность: под заказ, мало, много или не иссякаемо.
								</p>
							</div>
							{tree.map((node) => (
								<CatalogSection node={node} />
							))}
							{orphans.length > 0 && (
								<div class="folder-block">
									<h2 class="folder-title">Без группы / прочее</h2>
									<ul class="product-list">
										{orphans.map((p) => (
											<li class="product-card">
												<div class="product-name">{p.name}</div>
												{p.sku && <div class="product-sku">Код: {p.sku}</div>}
												{p.description && <p class="product-desc">{p.description}</p>}
												<div class="product-meta">
													<span class="price">
														{typeof p.price === 'number'
															? `${p.price.toLocaleString('ru-RU')} ₽`
															: p.price}
													</span>
													<span
														class={`availability-badge availability-badge--${stockAvailabilityBand(p.quantity)}`}
													>
														{stockAvailabilityLabel(p.quantity)}
													</span>
												</div>
											</li>
										))}
									</ul>
								</div>
							)}
						</>
					) : (
						<div class="folder-block">
							<h2 class="folder-title">Все товары</h2>
							<ul class="product-list">
								{products.map((p) => (
									<li class="product-card">
										<div class="product-name">{p.name}</div>
										{p.sku && <div class="product-sku">Код: {p.sku}</div>}
										{p.description && <p class="product-desc">{p.description}</p>}
										<div class="product-meta">
											<span class="price">
												{typeof p.price === 'number'
													? `${p.price.toLocaleString('ru-RU')} ₽`
													: p.price}
											</span>
											<span
												class={`availability-badge availability-badge--${stockAvailabilityBand(p.quantity)}`}
											>
												{stockAvailabilityLabel(p.quantity)}
											</span>
										</div>
									</li>
								))}
							</ul>
						</div>
					)
				}
			</div>
		</div>
		<SpeedInsights />
	</body>
</html>
