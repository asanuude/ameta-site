{
  "name": "ameta-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "catalog:build": "node scripts/commerceml-to-catalog.mjs --data-dir ./data --out ./catalog.json",
    "catalog:preview": "node scripts/commerceml-to-catalog.mjs --data-dir ./data --out ./public/catalog.json",
    "catalog:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-web1c.ps1",
    "catalog:sync-push": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/publish-catalog-from-1c.ps1"
  },
  "dependencies": {
    "@astrojs/vercel": "^10.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.0.4",
    "dotenv": "^17.3.1",
    "xml2js": "^0.6.2"
  }
}
